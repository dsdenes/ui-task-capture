{
  "name": "@dsdenes/ui-task-capture",
  "version": "0.1.0",
  "description": "Reusable UI issue capture primitives for browser apps and GitHub issue creation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dsdenes/ui-task-capture.git"
  },
  "homepage": "https://github.com/dsdenes/ui-task-capture#readme",
  "bugs": {
    "url": "https://github.com/dsdenes/ui-task-capture/issues"
  },
  "keywords": [
    "ui-capture",
    "issue-capture",
    "feedback",
    "github-issues",
    "dom"
  ],
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "pnpm@9.15.4",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "types": "./dist/esm/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src/",
    "pack:check": "npm pack --dry-run",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^9.0.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.0.0"
  }
}
